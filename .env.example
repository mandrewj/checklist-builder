# Copy to .env.local for local development; do not commit your filled-in copy.
# On Vercel, populate these via the Vercel Marketplace integrations (Neon,
# Clerk) and the project's Environment Variables tab.

# --- Database (Neon) ----------------------------------------------------------
# Pooled Neon connection string. Provided by the Neon Vercel Marketplace
# integration. For local dev, copy the pooled string from the Neon dashboard.
DATABASE_URL=postgres://USER:PASSWORD@HOST/DB?sslmode=require

# --- Auth (Clerk) -------------------------------------------------------------
# Provided by the Clerk Vercel Marketplace integration. For local dev, copy
# them from the API Keys page in your Clerk dashboard.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Signing secret for the Clerk webhook (user.created / user.updated /
# user.deleted). Create the endpoint at
# https://<deployment>/api/clerk/webhook in the Clerk dashboard, then paste
# the secret here.
CLERK_WEBHOOK_SIGNING_SECRET=whsec_...

# Optional Clerk sign-in/sign-up redirect overrides. Defaults are fine.
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# --- External APIs ------------------------------------------------------------
# Polite User-Agent strings — GBIF + iNat both expect contact info.
GBIF_USER_AGENT=checklist-builder (mailto:you@example.org)
INAT_USER_AGENT=checklist-builder (mailto:you@example.org)
